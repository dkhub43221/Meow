local function Close(callback)
	local t = TweenInfo.new(0.22, Enum.EasingStyle.Quad)
	TweenService:Create(Background, t, {BackgroundTransparency = 1}):Play()
	TweenService:Create(Blur, t, {Size = 0}):Play()
	TweenService:Create(Main, t, {BackgroundTransparency = 1}):Play()
	task.wait(0.22)
	Loader:Destroy()
	Blur:Destroy()
	if callback then callback() end
end

