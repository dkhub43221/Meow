local function CreateCard(name, lines, buttonText, delay)
	local Card = Instance.new("Frame")
	Card.Size = UDim2.new(0, 250, 0, 190)
	Card.BackgroundColor3 = Color3.fromRGB(22, 25, 31)
	Card.BorderSizePixel = 0
	Card.BackgroundTransparency = 1
	Card.ZIndex = 6
	Card.ClipsDescendants = true
	
	local CardCorner = Instance.new("UICorner")
	CardCorner.CornerRadius = UDim.new(0, 10)
	CardCorner.Parent = Card
	
	local CardStroke = Instance.new("UIStroke")
	CardStroke.Color = Color3.fromRGB(88, 255, 166)
	CardStroke.Thickness = 1.5
	CardStroke.Transparency = 1
	CardStroke.Parent = Card
	
	-- HOLOGRAM SCANLINE INSIDE CARD
	local Scanline = Instance.new("Frame")
	Scanline.Size = UDim2.new(1, 0, 0, 2)
	Scanline.Position = UDim2.new(0, 0, 0, 0)
	Scanline.BackgroundColor3 = Color3.fromRGB(88, 255, 166)
	Scanline.BackgroundTransparency = 0.9
	Scanline.BorderSizePixel = 0
	Scanline.ZIndex = 7
	Scanline.Parent = Card
	
	task.spawn(function()
		while Scanline.Parent do
			Scanline.Position = UDim2.new(0, 0, 0, 0)
			TweenService:Create(Scanline, TweenInfo.new(2, Enum.EasingStyle.Linear), {
				Position = UDim2.new(0, 0, 1, 0)
			}):Play()
			task.wait(3)
		end
	end)
	
	local CardTitle = Instance.new("TextLabel")
	CardTitle.Text = name
	CardTitle.Font = Enum.Font.GothamBold
	CardTitle.TextColor3 = Color3.fromRGB(88, 255, 166)
	CardTitle.TextSize = 17
	CardTitle.BackgroundTransparency = 1
	CardTitle.BorderSizePixel = 0
	CardTitle.Position = UDim2.new(0, 0, 0, 22)
	CardTitle.Size = UDim2.new(1, 0, 0, 22)
	CardTitle.TextTransparency = 1
	CardTitle.ZIndex = 7
	CardTitle.Parent = Card
	CardTitle.BackgroundColor3 = Card.BackgroundColor3
	
	for i, text in ipairs(lines) do
		local Desc = Instance.new("TextLabel")
		Desc.Text = "• " .. text
		Desc.Font = Enum.Font.Gotham
		Desc.TextColor3 = Color3.fromRGB(175, 175, 175)
		Desc.TextSize = 13
		Desc.BackgroundTransparency = 1
		Desc.BorderSizePixel = 0
		Desc.Position = UDim2.new(0, 22, 0, 52 + (i-1)*19)
		Desc.Size = UDim2.new(1, -44, 0, 16)
		Desc.TextXAlignment = Enum.TextXAlignment.Left
		Desc.TextTransparency = 1
		Desc.ZIndex = 7
		Desc.Parent = Card
		Desc.BackgroundColor3 = Card.BackgroundColor3
	end
	
	local Button = Instance.new("TextButton")
	Button.Text = buttonText
	Button.Font = Enum.Font.GothamSemibold
	Button.TextSize = 14
	Button.TextColor3 = Color3.fromRGB(15, 17, 22)
	Button.BackgroundColor3 = Color3.fromRGB(88, 255, 166)
	Button.Position = UDim2.new(0, 22, 1, -52)
	Button.Size = UDim2.new(1, -44, 0, 36)
	Button.AutoButtonColor = false
	Button.BackgroundTransparency = 1
	Button.TextTransparency = 1
	Button.BorderSizePixel = 0
	Button.ZIndex = 7
	
	local BtnCorner = Instance.new("UICorner")
	BtnCorner.CornerRadius = UDim.new(0, 7)
	BtnCorner.Parent = Button
	
	Button.Parent = Card
	Card.Parent = Container
	
	task.wait(delay)
	TweenService:Create(Card, TweenInfo.new(0.4, Enum.EasingStyle.Back), {BackgroundTransparency = 0}):Play()
	TweenService:Create(CardStroke, TweenInfo.new(0.4), {Transparency = 0.3}):Play()
	
	for _, child in ipairs(Card:GetChildren()) do
		if child:IsA("TextLabel") or child:IsA("TextButton") then
			TweenService:Create(child, TweenInfo.new(0.3), {TextTransparency = 0, BackgroundTransparency = 0}):Play()
		end
	end
	
	-- TEXT SCRAMBLE ON HOVER
	local originalText = Button.Text
	local chars = {"#", "$", "%", "&", "*", "@", "!", "?"}
	Button.MouseEnter:Connect(function()
		TweenService:Create(Button, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(98, 255, 176)}):Play()
		TweenService:Create(CardStroke, TweenInfo.new(0.15), {Transparency = 0.1, Thickness = 2}):Play()
		
		task.spawn(function()
			for i = 1, 3 do
				local scrambled = ""
				for j = 1, #originalText do
					scrambled = scrambled .. chars[math.random(1, #chars)]
				end
				Button.Text = scrambled
				task.wait(0.03)
			end
			Button.Text = originalText
		end)
	end)
	
	Button.MouseLeave:Connect(function()
		TweenService:Create(Button, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(88, 255, 166)}):Play()
		TweenService:Create(CardStroke, TweenInfo.new(0.15), {Transparency = 0.3, Thickness = 1.5}):Play()
	end)
	
	Button.MouseButton1Click:Connect(function()
		for i = 1, 20 do
			local Particle = Instance.new("Frame")
			Particle.Size = UDim2.new(0, math.random(2, 5), 0, math.random(2, 5))
			Particle.Position = UDim2.new(0.5, 0, 0.5, 0)
			Particle.AnchorPoint = Vector2.new(0.5, 0.5)
			Particle.BackgroundColor3 = Color3.fromRGB(88, 255, 166)
			Particle.BorderSizePixel = 0
			Particle.ZIndex = 9
			Particle.Parent = Button
			
			local PCorner = Instance.new("UICorner")
			PCorner.CornerRadius = UDim.new(1, 0)
			PCorner.Parent = Particle
			
			local angle = math.random() * math.pi * 2
			local dist = math.random(50, 100)
			TweenService:Create(Particle, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Position = UDim2.new(0.5, math.cos(angle) * dist, 0.5, math.sin(angle) * dist),
				BackgroundTransparency = 1,
				Size = UDim2.new(0, 0, 0, 0)
			}):Play()
			game:GetService("Debris"):AddItem(Particle, 0.6)
		end
	end)
	
	return Button
end

